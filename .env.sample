# --- NKUST AI Agent Workshop 環境設定範本 ---

# [必要] Google Gemini API Key / openai api key /ollama api key
GOOGLE_API_KEY=your_gemini_api_key_here
OLLAMA_API_KEY=your_ollama_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# [切換模式] Agent 執行模式 (gemini、openai 或 本地/雲端ollama)
AGENT_MODE=gemini

# [Ollama 連線設定] 預設 http://127.0.0.1:11434
OLLAMA_URL=http://127.0.0.1:11434


# [自定義模型] 具體使用的模型名稱 (預設: gemini-2.0-flash 或 gemma4)
MODEL_NAME=gemini-2.5-flash

# [Discord 整合] 階段二/三使用的 Webhook
# 取得方式: Discord 頻道 -> 編輯頻道 -> 整合 -> 建立 Webhook
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# --- 以下為 Google Calendar 參考設定 ---
# 取得方式: Google Cloud Console -> API -> Credentials -> OAuth 2.0
# GOOGLE_CALENDAR_CREDENTIALS=your-json-credentials
