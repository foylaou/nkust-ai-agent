# --- NKUST AI Agent Workshop 環境設定範本 ---

# [必要] Google Gemini API Key / openai api key /ollama api key /ollama web search
# 取得網址: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here
OLLAMA_API_KEY=your_ollama_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_WEB_SEARCH_API_KEY=your_openai_api_key_here


# [切換模式] Agent 執行模式 (gemini、openai 或 本地/雲端ollama)
AGENT_MODE=gemini

# [Ollama 連線設定] 預設 http://127.0.0.1:11434
OLLAMA_URL=http://127.0.0.1:11434


# [自定義模型] 具體使用的模型名稱 (預設: gemini-2.5-flash 或 gemma4)
MODEL_NAME=gemini-2.5-flash

# [Discord 整合] 階段二/三使用的 Webhook
# 取得方式: Discord 頻道 -> 編輯頻道 -> 整合 -> 建立 Webhook
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# --- 以下為 Google Calendar ﹑ Google Gmail api參考設定 ---
# 取得方式: Google Cloud Console -> API -> Credentials -> OAuth 2.0
# 請記得專案 Google Calendar &&  Google Gmail api 打開
GOOGLE_CALENDAR_CREDENTIALS=credentials.local.json
GOOGLE_GMAIL_CREDENTIALS=credentials.local.json



# ── Memory Backend ──────────────────────────────────────────────────────────
# 選擇後端: inmemory | postgres | redis
MEMORY_BACKEND=inmemory

# ── PostgreSQL (MEMORY_BACKEND=postgres 時需要) ──────────────────────────────
# 可以直接給整條 DSN，或拆開設定
# POSTGRES_DSN=host=localhost port=5432 dbname=adk_memory user=postgres password=secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=adk_memory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secret

# ── Redis (MEMORY_BACKEND=redis 時需要) ──────────────────────────────────────
# 需要 Redis Stack 或安裝 RediSearch module
# Docker 快速啟動: docker run -p 6379:6379 redis/redis-stack-server
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
